{
  "name": "@kairo/api",
  "version": "1.0.0",
  "description": "Kairo AI — Backend API",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec \"node --import tsx/esm src/server.ts\" --ext ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "test": "echo \"tests pendientes\" && exit 0",
    "migrate:up": "node-pg-migrate up --migrations-dir db/migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir db/migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir db/migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/node-pg-migrate": "^2.3.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
