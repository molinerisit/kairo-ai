# ── Requeridas ───────────────────────────────────────────────────────────────
# Railway las provee automáticamente al agregar el plugin de PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-secret-at-least-32-chars

# ── Opcionales ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# URL del frontend en Vercel (para CORS)
ALLOWED_ORIGIN=https://kairo-web.vercel.app

# Tiempo de vida de los tokens JWT
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic (requerida para el agente secretario)
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Business API (requerida para el webhook)
WHATSAPP_VERIFY_TOKEN=tu-token-secreto-de-verificacion
WHATSAPP_ACCESS_TOKEN=EAAxxxxx...
WHATSAPP_PHONE_NUMBER_ID=123456789012345
